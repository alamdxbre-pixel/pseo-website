# Site URL (required for sitemap and canonical generation)
SITE_URL=https://yoursite.com

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
PUBLIC_GA4_ID=

# Microsoft Clarity Project ID
PUBLIC_CLARITY_ID=

# Arabic language feature flag — set to "true" when AR content is ready
ENABLE_ARABIC=false

# WhatsApp Business number (country code + number, no + or spaces)
# Example: 971501234567
WHATSAPP_NUMBER=971528955506
