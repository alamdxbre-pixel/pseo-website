---
/**
 * CountdownTimer block — thin Astro wrapper around CountdownTimerIsland (React).
 * Uses client:visible so the island only hydrates when scrolled into view,
 * keeping it a proper client island while other blocks remain static HTML.
 */
import CountdownTimerIsland from './CountdownTimerIsland';

interface Props {
  end_date: string;
  label?: string;
}

const { end_date, label } = Astro.props;
---

<CountdownTimerIsland endDate={end_date} label={label} client:visible />
