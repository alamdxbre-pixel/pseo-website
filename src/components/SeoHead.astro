---
/**
 * SeoHead — renders all non-JSON-LD <head> meta for every page.
 *
 * Usage:
 *   import SeoHead from '@/components/SeoHead.astro';
 *   <SeoHead {...data} siteUrl={import.meta.env.SITE} />
 */

interface RobotsMeta {
  index?: boolean;
  follow?: boolean;
  max_snippet?: number;
  max_image_preview?: 'none' | 'standard' | 'large';
  max_video_preview?: number;
}

interface GeoMeta {
  region: string;
  placename: string;
  position: string;
  icbm: string;
}

interface OgMeta {
  title: string;
  description: string;
  image?: string;
  image_width?: number;
  image_height?: number;
  type?: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  robots?: RobotsMeta;
  geo?: GeoMeta;
  og?: OgMeta;
  lang?: string;
  /** Fully-qualified site origin e.g. "https://example.com" — no trailing slash */
  siteUrl?: string;
  /** ISO 8601 date for article:modified_time */
  date_modified?: string;
  /** ISO 8601 date for article:published_time */
  date_published?: string;
  /**
   * Full URL of the paired alternate-language page.
   * When ENABLE_ARABIC=true and this is set, hreflang alternate links are emitted.
   */
  hreflangPairUrl?: string;
}

const {
  title,
  description,
  canonical,
  robots = {},
  geo,
  og,
  lang = 'en',
  siteUrl = '',
  date_modified,
  date_published,
  hreflangPairUrl,
} = Astro.props;

// ── ENABLE_ARABIC feature flag ───────────────────────────────────────────────
const arabicEnabled = import.meta.env.ENABLE_ARABIC === 'true';
// Hreflang is only emitted when the flag is on AND a pair URL is provided.
const emitHreflang = arabicEnabled && !!hreflangPairUrl;

// ── robots content string ────────────────────────────────────────────────────
const robotsParts: string[] = [
  robots.index !== false ? 'index' : 'noindex',
  robots.follow !== false ? 'follow' : 'nofollow',
  `max-snippet:${robots.max_snippet ?? -1}`,
  `max-image-preview:${robots.max_image_preview ?? 'large'}`,
  `max-video-preview:${robots.max_video_preview ?? -1}`,
];
const robotsContent = robotsParts.join(', ');

// ── canonical href ───────────────────────────────────────────────────────────
const canonicalHref = canonical.startsWith('http')
  ? canonical
  : `${siteUrl}${canonical}`;
---

<!-- Primary meta -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalHref} />
<meta name="robots" content={robotsContent} />
<meta name="language" content={lang} />

<!-- Hreflang alternate links (only when ENABLE_ARABIC=true) -->
{emitHreflang && lang === 'en' && (
  <>
    <link rel="alternate" hreflang="en-AE" href={canonicalHref} />
    <link rel="alternate" hreflang="ar-AE" href={hreflangPairUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalHref} />
  </>
)}
{emitHreflang && lang === 'ar' && (
  <>
    <link rel="alternate" hreflang="ar-AE" href={canonicalHref} />
    <link rel="alternate" hreflang="en-AE" href={hreflangPairUrl} />
    <link rel="alternate" hreflang="x-default" href={hreflangPairUrl} />
  </>
)}

<!-- Geo targeting -->
{geo && (
  <>
    <meta name="geo.region" content={geo.region} />
    <meta name="geo.placename" content={geo.placename} />
    <meta name="geo.position" content={geo.position} />
    <meta name="ICBM" content={geo.icbm} />
  </>
)}

<!-- Open Graph -->
{og && (
  <>
    <meta property="og:site_name" content="BrandName" />
    <meta property="og:locale" content={lang === 'ar' ? 'ar_AE' : 'en_AE'} />
    <meta property="og:type" content={og.type ?? 'website'} />
    <meta property="og:title" content={og.title} />
    <meta property="og:description" content={og.description} />
    <meta property="og:url" content={canonicalHref} />
    {og.image && <meta property="og:image" content={og.image} />}
    {og.image && og.image_width && (
      <meta property="og:image:width" content={String(og.image_width)} />
    )}
    {og.image && og.image_height && (
      <meta property="og:image:height" content={String(og.image_height)} />
    )}
    {og.image && <meta property="og:image:alt" content={og.title} />}
    {date_published && <meta property="article:published_time" content={date_published} />}
    {date_modified && <meta property="article:modified_time" content={date_modified} />}
  </>
)}

<!-- Twitter Card -->
<meta name="twitter:card" content={og?.image ? 'summary_large_image' : 'summary'} />
<meta name="twitter:title" content={og?.title ?? title} />
<meta name="twitter:description" content={og?.description ?? description} />
{og?.image && <meta name="twitter:image" content={og.image} />}
{og?.image && <meta name="twitter:image:alt" content={og.title} />}
