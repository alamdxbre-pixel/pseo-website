---
/**
 * Footer — site-wide footer with city links, category links, trust badges.
 * The sticky WhatsApp mobile bar is a separate component (WhatsAppBar.astro)
 * so it can be conditionally included without JS.
 */

const currentYear = new Date().getFullYear();

const cities = [
  { label: 'Dubai', href: '/print/visiting-cards/dubai-300gsm-gloss' },
  { label: 'Abu Dhabi', href: '/abudhabi' },
  { label: 'Sharjah', href: '/sharjah' },
  { label: 'Ajman', href: '/ajman' },
  { label: 'Ras Al Khaimah', href: '/rak' },
  { label: 'Fujairah', href: '/fujairah' },
];

const categories = [
  { label: 'Print', href: '/print' },
  { label: 'Apparel', href: '/apparel' },
  { label: 'Merchandise & Gifts', href: '/merchandise' },
  { label: 'Digital Services', href: '/digital' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Portfolio', href: '/portfolio' },
  { label: 'Campaigns & Offers', href: '/campaigns' },
  { label: 'Contact', href: '/contact' },
];

const trustBadges = [
  { icon: '⭐', title: '5-Star Google Reviews', sub: '400+ verified reviews' },
  { icon: '⚡', title: 'Same-Day Dispatch', sub: 'Order before 2 PM' },
  { icon: '🚚', title: 'UAE-Wide Delivery', sub: 'Dubai · Abu Dhabi · All Emirates' },
  { icon: '🔒', title: 'Secure Payments', sub: 'Bank transfer · Cards · Apple Pay' },
];
---

<footer class="bg-[var(--color-brand-charcoal)] text-white">

  <!-- ── Trust badges ──────────────────────────────────────────────────────── -->
  <div class="border-b border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {trustBadges.map((badge) => (
          <div class="flex items-start gap-3">
            <span class="text-2xl" aria-hidden="true">{badge.icon}</span>
            <div>
              <p class="font-semibold text-sm">{badge.title}</p>
              <p class="text-xs text-white/60 mt-0.5">{badge.sub}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ── Main link columns ─────────────────────────────────────────────────── -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 font-bold text-xl mb-4 hover:text-[var(--color-brand-accent)] transition-colors">
          <span class="w-8 h-8 rounded-lg bg-[var(--color-brand-accent)] text-white flex items-center justify-center text-sm font-bold">
            U
          </span>
          Upshot Solutions
        </a>
        <p class="text-sm text-white/60 leading-relaxed mb-6">
          UAE's trusted partner for print, packaging and advertising. Fast delivery, competitive pricing, and outstanding quality for every budget.
        </p>
        <a
          href={`https://wa.me/${import.meta.env.WHATSAPP_NUMBER ?? '971500000000'}?text=${encodeURIComponent('Hi, I would like to get a quote.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold rounded-lg transition-colors"
          aria-label="Chat with us on WhatsApp"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L0 24l6.336-1.51A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.817 9.817 0 01-5.002-1.366l-.358-.213-3.762.896.952-3.665-.234-.377A9.818 9.818 0 012.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/>
          </svg>
          Chat on WhatsApp
        </a>
      </div>

      <!-- Products column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">Products</h3>
        <ul class="space-y-2">
          {categories.map((cat) => (
            <li>
              <a
                href={cat.href}
                class="text-sm text-white/70 hover:text-white hover:text-[var(--color-brand-accent)] transition-colors"
              >
                {cat.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Cities column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">Order By City</h3>
        <ul class="space-y-2">
          {cities.map((city) => (
            <li>
              <a
                href={city.href}
                class="text-sm text-white/70 hover:text-white transition-colors"
              >
                {city.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-white/40 mb-4">Company</h3>
        <ul class="space-y-2">
          {company.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-white/70 hover:text-white transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- ── Bottom bar ─────────────────────────────────────────────────────────── -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/40">
      <p>© {currentYear} Upshot Solutions. All rights reserved.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms of Use</a>
        <a href="/sitemap-index.xml" class="hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>

</footer>
