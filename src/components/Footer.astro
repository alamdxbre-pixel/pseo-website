---
import { SHOW_SERVICES } from '@/lib/flags';

const currentYear = new Date().getFullYear();

const techServices = [
  { label: 'IT Consultancy',              href: '/services/it-ai#it-consultancy' },
  { label: 'Custom Software Engineering', href: '/services/it-ai#custom-software-engineering' },
  { label: 'Microservice Architecture',   href: '/services/it-ai#microservice-architecture' },
  { label: 'SaaS Platform Engineering',   href: '/services/it-ai#saas-platform-engineering' },
  { label: 'RAG & Knowledge Systems',     href: '/services/it-ai#rag-knowledge-systems' },
  { label: 'AI Model Training',           href: '/services/it-ai#ai-model-training' },
];

const company = [
  { label: 'About Us', href: '/about' },
  { label: 'Contact', href: '/contact' },
];

const regions = [
  { label: 'Dubai', href: '/about' },
  { label: 'Abu Dhabi', href: '/about' },
  { label: 'Sharjah', href: '/about' },
  { label: 'Ajman', href: '/about' },
  { label: 'Ras Al Khaimah', href: '/about' },
  { label: 'GCC & Global', href: '/about' },
];

const credentials = [
  { label: '35+ Years Combined Experience', sub: 'Senior engineers on every engagement — no juniors, no handoffs' },
  { label: 'Full IP Transfer', sub: 'Source code, docs, and configs handed over at every milestone' },
  { label: 'Direct Engineer Access', sub: 'You work with the people writing your code — no account managers' },
  { label: 'Response Within 48 Hours', sub: 'A technical assessment, not a sales pitch' },
];
---

<footer class="bg-[#030B18] text-white">

  <!-- Credentials strip -->
  <div class="border-b border-white/[0.06]">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {credentials.map((c) => (
          <div class="flex flex-col gap-1">
            <p class="text-sm font-semibold text-white/80">{c.label}</p>
            <p class="text-xs text-white/30">{c.sub}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Main columns -->
  <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-16">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-flex items-center gap-2.5 mb-6" aria-label="BuoyantSolutions">
          <span class="w-7 h-7 rounded bg-blue-500 text-white flex items-center justify-center text-xs font-bold shrink-0">B</span>
          <span class="text-white text-lg" style="font-family: 'Glacial Indifference', sans-serif; font-weight: 700;">Buoyant <span style="font-weight: 400;">solutions</span></span>
        </a>
        <p class="text-sm text-white/30 leading-relaxed mb-8">
          Enterprise AI engineering for organisations that operate at scale. UAE-headquartered. Globally delivered.
        </p>
        <a
          href={`https://wa.me/${import.meta.env.WHATSAPP_NUMBER ?? '97152895506'}?text=${encodeURIComponent('Hi, I would like to discuss an AI engineering project.')}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 border border-white/10 text-white/50 text-xs font-semibold rounded hover:border-white/20 hover:text-white/80 transition-colors"
          aria-label="Contact us on WhatsApp"
        >
          <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L0 24l6.336-1.51A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.817 9.817 0 01-5.002-1.366l-.358-.213-3.762.896.952-3.665-.234-.377A9.818 9.818 0 012.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/>
          </svg>
          WhatsApp
        </a>
      </div>

      <!-- Services -->
      {SHOW_SERVICES && (
        <div>
          <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 mb-5">Services</h3>
          <ul class="space-y-3">
            {techServices.map((item) => (
              <li>
                <a href={item.href} class="text-sm text-white/40 hover:text-white transition-colors">
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <!-- Regions -->
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 mb-5">Regions Served</h3>
        <ul class="space-y-3">
          {regions.map((r) => (
            <li>
              <span class="text-sm text-white/40">
                {r.label}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-white/20 mb-5">Company</h3>
        <ul class="space-y-3">
          {company.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-white/40 hover:text-white transition-colors">
                {item.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/marketing" class="text-sm text-blue-400/60 hover:text-blue-400 transition-colors">
              Buoyant Marketing &rarr;
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/[0.05]">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/20">
      <p>&copy; {currentYear} Buoyant Solutions L.L.C FZ &nbsp;&middot;&nbsp; All rights reserved</p>
      <div class="flex items-center gap-5">
        <a href="/privacy" class="hover:text-white/50 transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-white/50 transition-colors">Terms</a>
        <a href="/sitemap-index.xml" class="hover:text-white/50 transition-colors">Sitemap</a>
      </div>
    </div>
  </div>

</footer>
