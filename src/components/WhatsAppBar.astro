---
/**
 * WhatsAppBar — sticky mobile-only bar fixed at the bottom of the viewport.
 * Hidden on md+ breakpoints via Tailwind. Body padding applied in Base layout.
 *
 * When product context props are passed, generates a pre-filled product quote link.
 * Falls back to a generic enquiry link when used on non-product pages.
 */
import { buildProductWhatsAppLink, buildWhatsAppLink } from '@/lib/utils';

interface Props {
  product?: string;
  variant?: string;
  city?: string;
}

const { product, variant, city } = Astro.props;
const phone = import.meta.env.WHATSAPP_NUMBER ?? '971500000000';

const href = product && city
  ? buildProductWhatsAppLink({ product, variant, city, phoneNumber: phone })
  : buildWhatsAppLink(phone, "Hi, I'd like to get a quote for my order.");
---

<!-- Sticky WhatsApp bar — mobile only (md:hidden) -->
<div
  class="fixed bottom-0 inset-x-0 z-40 md:hidden"
  role="complementary"
  aria-label="WhatsApp quick contact"
>
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    data-wa-product={product}
    data-wa-variant={variant}
    data-wa-city={city}
    data-wa-link
    class="flex items-center justify-center gap-3 w-full py-4 bg-green-500 text-white font-semibold text-sm shadow-[0_-4px_20px_rgba(0,0,0,0.15)] hover:bg-green-600 transition-colors"
    aria-label="Chat with us on WhatsApp to get an instant quote"
  >
    <!-- WhatsApp icon -->
    <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L0 24l6.336-1.51A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.817 9.817 0 01-5.002-1.366l-.358-.213-3.762.896.952-3.665-.234-.377A9.818 9.818 0 012.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/>
    </svg>
    <span>Chat on WhatsApp — Get an Instant Quote</span>
  </a>
</div>

<script>
  import { trackWhatsAppClick } from '@/lib/analytics';
  document.querySelector('[data-wa-link]')?.addEventListener('click', (e) => {
    const el = e.currentTarget as HTMLAnchorElement;
    trackWhatsAppClick({
      product: el.dataset.waProduct,
      variant: el.dataset.waVariant,
      city: el.dataset.waCity,
    });
  });
</script>
