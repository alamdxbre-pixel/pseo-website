---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { buildProductWhatsAppLink, formatPrice } from '@/lib/utils';

// ── Data ──────────────────────────────────────────────────────────────────────
const allProducts = await getCollection('products', ({ data }) => data.published);

// Group: category → product-type → entries[]
type ProductEntry = (typeof allProducts)[number];
const grouped = new Map<string, Map<string, ProductEntry[]>>();
for (const entry of allProducts) {
  const { category, product } = entry.data;
  if (!grouped.has(category)) grouped.set(category, new Map());
  const catMap = grouped.get(category)!;
  if (!catMap.has(product)) catMap.set(product, []);
  catMap.get(product)!.push(entry);
}
// Sort city variants alphabetically within each group
for (const catMap of grouped.values()) {
  for (const [key, entries] of catMap.entries()) {
    catMap.set(
      key,
      entries.sort((a, b) =>
        a.data.product_details.city.localeCompare(b.data.product_details.city)
      )
    );
  }
}

// Static category metadata — covers existing + future categories
const categoryMeta: Record<string, { label: string; desc: string; emoji: string }> = {
  print: {
    label: 'Print & Stationery',
    desc: 'Visiting cards, flyers, brochures, banners and large-format print across all seven emirates.',
    emoji: '🖨️',
  },
  apparel: {
    label: 'Apparel & Uniforms',
    desc: 'Custom T-shirts, polos, caps and branded workwear embroidered or printed to your spec.',
    emoji: '👕',
  },
  merchandise: {
    label: 'Branded Merchandise',
    desc: 'Pens, mugs, tote bags, USB drives and premium corporate gift sets.',
    emoji: '🎁',
  },
  digital: {
    label: 'Digital Services',
    desc: 'Social media graphics, email signatures, digital brochures and online ad creatives.',
    emoji: '💻',
  },
};

function productTypeLabel(slug: string): string {
  const map: Record<string, string> = {
    'visiting-cards': 'Visiting Cards',
    flyers: 'Flyers',
    brochures: 'Brochures',
    letterheads: 'Letterheads',
    banners: 'Banners',
    'roll-up-banners': 'Roll-Up Banners',
    'tshirts': 'T-Shirts',
    caps: 'Caps',
    polos: 'Polo Shirts',
    mugs: 'Mugs',
    pens: 'Pens',
  };
  return map[slug] ?? slug.replace(/-/g, ' ').replace(/\b\w/g, (c) => c.toUpperCase());
}

// All categories in preferred display order
const displayCategories = ['print', 'apparel', 'merchandise', 'digital'];

const phone = import.meta.env.WHATSAPP_NUMBER ?? '971500000000';
const totalCount = allProducts.length;
---

<Base
  title="All Products — Print, Packaging & Advertising UAE | Upshot Solutions"
  description="Browse our full catalogue of customised marketing products in UAE — visiting cards, flyers, apparel, merchandise and digital services. Competitive pricing, fast UAE delivery."
  canonical="/products"
  og={{
    title: 'All Products — Marketing Products UAE',
    description: 'Full catalogue of customised print, apparel, merchandise and digital services. Delivered fast across Dubai, Abu Dhabi, Sharjah and all seven emirates.',
    type: 'website',
  }}
>

  <!-- ── Hero ───────────────────────────────────────────────────────────────── -->
  <section class="bg-[var(--color-brand-charcoal)] text-white">
    <div class="max-w-6xl mx-auto px-4 py-16 md:py-24">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <div class="flex items-center gap-2 mb-4">
            <span class="inline-block w-1 h-6 bg-[var(--color-brand-charcoal)] rounded-full"></span>
            <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-brand-charcoal)]">
              Product Catalogue
            </p>
          </div>
          <h1 class="text-4xl md:text-5xl font-extrabold leading-tight mb-4">
            All Products
          </h1>
          <p class="text-white/70 text-lg max-w-xl leading-relaxed">
            Print, apparel, merchandise and digital services — all in one place.
            Fast delivery across every UAE emirate.
          </p>
        </div>
        <div class="flex items-center gap-4 shrink-0">
          <div class="text-center border border-white/20 rounded-xl px-6 py-4">
            <p class="text-3xl font-extrabold text-[var(--color-brand-charcoal)]">{totalCount}+</p>
            <p class="text-white/60 text-xs mt-1 uppercase tracking-wide">SKUs Available</p>
          </div>
          <div class="text-center border border-white/20 rounded-xl px-6 py-4">
            <p class="text-3xl font-extrabold text-[var(--color-brand-charcoal)]">7</p>
            <p class="text-white/60 text-xs mt-1 uppercase tracking-wide">Emirates</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Category filter tabs ───────────────────────────────────────────────── -->
  <div class="sticky top-0 z-30 bg-white border-b border-slate-200 shadow-sm">
    <div class="max-w-6xl mx-auto px-4">
      <nav aria-label="Product categories" class="flex gap-1 overflow-x-auto scrollbar-none -mb-px py-1">
        {displayCategories.map((cat) => {
          const meta = categoryMeta[cat];
          const hasProducts = grouped.has(cat);
          return (
            <a
              href={`#${cat}`}
              class={`flex items-center gap-2 px-4 py-3 text-sm font-semibold whitespace-nowrap border-b-2 transition-colors ${
                hasProducts
                  ? 'border-transparent text-slate-600 hover:text-[var(--color-brand-charcoal)] hover:border-[var(--color-brand-charcoal)]'
                  : 'border-transparent text-slate-400 cursor-default pointer-events-none'
              }`}
            >
              <span aria-hidden="true">{meta.emoji}</span>
              {meta.label}
              {!hasProducts && (
                <span class="text-[10px] bg-slate-100 text-slate-400 px-1.5 py-0.5 rounded-full font-medium">Soon</span>
              )}
            </a>
          );
        })}
      </nav>
    </div>
  </div>

  <!-- ── Product sections ───────────────────────────────────────────────────── -->
  <div class="bg-[var(--color-brand-cream)] min-h-screen">
    <div class="max-w-6xl mx-auto px-4 py-12 space-y-20">

      {displayCategories.map((cat) => {
        const meta = categoryMeta[cat];
        const catMap = grouped.get(cat);

        return (
          <section id={cat} class="scroll-mt-20">
            <!-- Category heading -->
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-10">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-2xl" aria-hidden="true">{meta.emoji}</span>
                  <h2 class="text-2xl md:text-3xl font-extrabold text-[var(--color-brand-charcoal)]">
                    {meta.label}
                  </h2>
                </div>
                <p class="text-slate-500 text-sm max-w-xl">{meta.desc}</p>
              </div>
              {catMap && (
                <a
                  href={`/${cat}`}
                  class="shrink-0 text-sm font-semibold text-[var(--color-brand-charcoal)] hover:underline"
                >
                  View category page →
                </a>
              )}
            </div>

            {catMap ? (
              <div class="space-y-14">
                {[...catMap.entries()].map(([productSlug, entries]) => (
                  <div>
                    <!-- Product-type sub-heading -->
                    <div class="flex items-center gap-3 mb-6">
                      <h3 class="text-lg font-bold text-[var(--color-brand-charcoal)]">
                        {productTypeLabel(productSlug)}
                      </h3>
                      <span class="h-px flex-1 bg-slate-200"></span>
                      <span class="text-xs text-slate-400 font-medium">{entries.length} variants</span>
                    </div>

                    <!-- Cards grid -->
                    <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5 list-none p-0" role="list">
                      {entries.map((entry) => {
                        const { data } = entry;
                        const href = `/${data.category}/${data.product}/${data.page_slug}/`;
                        const waHref = buildProductWhatsAppLink({
                          product: productTypeLabel(data.product),
                          city: data.product_details.city,
                          variant: data.product_details.variant,
                          phoneNumber: phone,
                        });
                        return (
                          <li class="group bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-md hover:border-[var(--color-brand-charcoal)]/30 transition-all duration-200 flex flex-col overflow-hidden">
                            <!-- Card header: city + turnaround -->
                            <div class="flex items-start justify-between px-5 pt-5 pb-3">
                              <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-brand-charcoal)] bg-[var(--color-brand-charcoal)]/8 px-2.5 py-1 rounded-full">
                                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                                {data.product_details.city}
                              </span>
                              <span class="text-[10px] font-medium text-green-700 bg-green-50 border border-green-200 px-2 py-0.5 rounded-full">
                                {data.product_details.turnaround}
                              </span>
                            </div>

                            <!-- Variant label -->
                            <div class="px-5 pb-1">
                              {data.product_details.variant && (
                                <p class="text-xs font-semibold uppercase tracking-wider text-slate-400 mb-0.5">
                                  {data.product_details.variant}
                                </p>
                              )}
                              <p class="text-[var(--color-brand-charcoal)] font-bold text-base leading-snug line-clamp-2">
                                {data.hero.headline}
                              </p>
                            </div>

                            <!-- Price + min qty -->
                            <div class="flex items-baseline gap-2 px-5 pt-3 pb-4">
                              <span class="text-xl font-extrabold text-[var(--color-brand-charcoal)]">
                                {formatPrice(data.product_details.price_from, data.product_details.currency)}
                              </span>
                              {data.product_details.min_quantity && (
                                <span class="text-xs text-slate-400">
                                  min {data.product_details.min_quantity}
                                </span>
                              )}
                            </div>

                            <!-- Availability -->
                            <div class="px-5 pb-4 flex items-center gap-1.5">
                              <span class={`w-1.5 h-1.5 rounded-full ${data.product_details.availability === 'InStock' ? 'bg-green-500' : 'bg-amber-400'}`}></span>
                              <span class="text-[11px] text-slate-500 font-medium">
                                {data.product_details.availability === 'InStock' ? 'In Stock' : data.product_details.availability}
                              </span>
                            </div>

                            <!-- CTAs -->
                            <div class="mt-auto border-t border-slate-100 grid grid-cols-2 divide-x divide-slate-100">
                              <a
                                href={href}
                                class="flex items-center justify-center gap-1.5 py-3.5 text-xs font-semibold text-[var(--color-brand-charcoal)] hover:text-[var(--color-brand-charcoal)] hover:bg-slate-50 transition-colors"
                              >
                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                                View Details
                              </a>
                              <a
                                href={waHref}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex items-center justify-center gap-1.5 py-3.5 text-xs font-semibold text-green-700 hover:bg-green-50 transition-colors"
                              >
                                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.124 1.535 5.856L.057 23.571a.75.75 0 0 0 .921.921l5.715-1.478A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.882 0-3.643-.51-5.148-1.395l-.369-.215-3.831.99.99-3.831-.215-.369A9.966 9.966 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                                Get Quote
                              </a>
                            </div>
                          </li>
                        );
                      })}
                    </ul>
                  </div>
                ))}
              </div>
            ) : (
              <!-- Coming soon placeholder -->
              <div class="rounded-2xl border-2 border-dashed border-slate-300 bg-white/60 px-8 py-16 text-center">
                <p class="text-4xl mb-4" aria-hidden="true">{meta.emoji}</p>
                <h3 class="text-lg font-bold text-slate-600 mb-2">{meta.label} — Coming Soon</h3>
                <p class="text-slate-400 text-sm max-w-sm mx-auto mb-6">
                  We're adding this range to the catalogue. Get in touch and we'll sort it out for you today.
                </p>
                <a
                  href={`https://wa.me/${phone}?text=${encodeURIComponent(`Hi, I'm interested in ${meta.label}. Can you share what's available?`)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-5 py-2.5 rounded-xl transition-colors"
                >
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.124 1.535 5.856L.057 23.571a.75.75 0 0 0 .921.921l5.715-1.478A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.882 0-3.643-.51-5.148-1.395l-.369-.215-3.831.99.99-3.831-.215-.369A9.966 9.966 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                  Ask on WhatsApp
                </a>
              </div>
            )}
          </section>
        );
      })}

    </div>
  </div>

  <!-- ── Bottom CTA banner ───────────────────────────────────────────────────── -->
  <section class="bg-[var(--color-brand-charcoal)] text-white">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <h2 class="text-2xl md:text-3xl font-extrabold mb-4">Can't find what you need?</h2>
      <p class="text-white/70 mb-8 text-lg">
        We handle custom orders, bulk quotes and bespoke product development. Just ask.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={`https://wa.me/${phone}?text=${encodeURIComponent("Hi, I have a custom product enquiry. Can you help?")}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-xl transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.124 1.535 5.856L.057 23.571a.75.75 0 0 0 .921.921l5.715-1.478A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.882 0-3.643-.51-5.148-1.395l-.369-.215-3.831.99.99-3.831-.215-.369A9.966 9.966 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
          WhatsApp Us
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 border border-white/30 hover:border-white text-white font-semibold px-6 py-3 rounded-xl transition-colors"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>

</Base>
