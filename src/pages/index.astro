---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { buildWhatsAppLink } from '@/lib/utils';
import { CATEGORY_PHOTO_CARDS, STATS_TYPEWRITER, HOW_IT_WORKS_FLOW, TECH_SHOWCASE, HERO_BADGE_HIGHLIGHT, HERO_CITY_CYCLE, BROWSE_IN_TICKER, HERO_PRINTER_BG } from '@/lib/flags';

// Pull a handful of featured products for the homepage grid
const allProducts = await getCollection('products', ({ data }) => data.published);
// Show Dubai products first (city-variant diversity), up to 6
const featured = allProducts
  .filter((p) => p.data.product_details.city === 'Dubai')
  .slice(0, 6);

const phone = import.meta.env.WHATSAPP_NUMBER ?? '971500000000';
const waHref = buildWhatsAppLink(phone, "Hi, I'd like to get a quote for marketing products.");

const siteUrl = import.meta.env.SITE ?? '';

const categories = [
  {
    slug: 'print',
    label: 'Print & Stationery',
    desc: 'Visiting cards, flyers, brochures, letterheads and more.',
    image: 'https://images.unsplash.com/photo-1586281380349-632531db7ed4?auto=format&fit=crop&w=800&q=75',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/><line x1="9" y1="17" x2="9" y2="17"/><line x1="12" y1="17" x2="15" y2="17"/></svg>`,
    href: '/print',
  },
  {
    slug: 'apparel',
    label: 'Apparel & Uniforms',
    desc: 'Custom T-shirts, polos, caps and branded workwear.',
    image: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?auto=format&fit=crop&w=800&q=75',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.38 3.46 16 2a4 4 0 0 1-8 0L3.62 3.46a2 2 0 0 0-1.34 2.23l.58 3.57a1 1 0 0 0 .99.84H6v10c0 .55.45 1 1 1h10c.55 0 1-.45 1-1V10h2.15a1 1 0 0 0 .99-.84l.58-3.57a2 2 0 0 0-1.34-2.23z"/></svg>`,
    href: '/apparel',
  },
  {
    slug: 'merchandise',
    label: 'Branded Merchandise',
    desc: 'Pens, mugs, bags, USB drives and corporate gifts.',
    image: 'https://images.unsplash.com/photo-1607082348824-0a96f2a4b9da?auto=format&fit=crop&w=800&q=75',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>`,
    href: '/merchandise',
  },
  {
    slug: 'digital',
    label: 'Digital Services',
    desc: 'Social media graphics, email signatures and digital ads.',
    image: 'https://images.unsplash.com/photo-1467232004584-a241de8bcf5d?auto=format&fit=crop&w=800&q=75',
    icon: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
    href: '/digital',
  },
];

const stats = [
  { value: '10+', label: 'Years in UAE' },
  { value: '2,500+', label: 'Happy Clients' },
  { value: '24 hrs', label: 'Avg. Turnaround' },
  { value: '7', label: 'Emirates Covered' },
];

const testimonials = [
  {
    body: 'Ordered 500 gloss visiting cards on Tuesday — received them Wednesday morning. Quality was exceptional.',
    author: 'Ahmed Al Mansoori',
    role: 'CEO, Al Mansoori Ventures',
    city: 'Dubai',
  },
  {
    body: 'Upshot Solutions printed our entire corporate identity kit. Consistent quality across every piece.',
    author: 'Sara Khalifa',
    role: 'Brand Manager, Gulf Holdings',
    city: 'Abu Dhabi',
  },
  {
    body: "Fast, responsive team. We've been using them for trade show materials for 5 years straight.",
    author: 'James O\'Brien',
    role: 'Marketing Director, EMEA Corp',
    city: 'Dubai',
  },
];
---

<Base
  title="Upshot Solutions | Print, Packaging & Advertising UAE"
  description="Upshot Solutions — UAE's trusted partner for print, packaging and advertising. Visiting cards, flyers, apparel, branded merchandise and digital services. Fast delivery across Dubai, Abu Dhabi and all seven emirates."
  canonical="/"
  og={{
    title: 'Upshot Solutions | Print, Packaging & Advertising UAE',
    description: 'Print · Packaging · Advertising — delivered fast across UAE. Visiting cards, flyers, apparel, branded merchandise and digital services.',
    type: 'website',
    image_width: 1200,
    image_height: 630,
  }}
>
  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-[var(--color-brand-charcoal)] text-white">

    {HERO_PRINTER_BG ? (
      /* ── Printer photo variant ──
         Layer order (back → front):
         1. Charcoal base (section bg)
         2. Printer photo — right-anchored, mix-blend-mode:luminosity strips
            colour so the industrial tones merge into the dark bg naturally
         3. Left-to-right gradient — solid charcoal over the text, fading to
            near-transparent at the right edge so the printer shows through
         4. Top + bottom vignettes — blend edges into header / ticker strip
         5. Teal accent bar (left edge) – same as original
      */
      <>
        {/* Printer photo */}
        <div
          class="absolute inset-0 bg-cover bg-right bg-no-repeat"
          style={`background-image:url('https://images.unsplash.com/photo-1758183961426-88d64eb5f787?w=1600&q=80');mix-blend-mode:luminosity;opacity:0.45;`}
          aria-hidden="true"
        />
        {/* Left-to-right dark gradient — protects text, reveals printer on right */}
        <div
          class="absolute inset-0"
          style="background:linear-gradient(to right, #0B1F3B 0%, #0B1F3B 38%, rgba(11,31,59,0.75) 56%, rgba(11,31,59,0.18) 82%, rgba(11,31,59,0.04) 100%);"
          aria-hidden="true"
        />
        {/* Top vignette — blends into navbar */}
        <div
          class="absolute top-0 inset-x-0 h-20"
          style="background:linear-gradient(to bottom,#0B1F3B 0%,transparent 100%);"
          aria-hidden="true"
        />
        {/* Bottom vignette — blends into ticker strip */}
        <div
          class="absolute bottom-0 inset-x-0 h-28"
          style="background:linear-gradient(to top,#0B1F3B 0%,transparent 100%);"
          aria-hidden="true"
        />
        {/* Teal accent bar — left edge, same as original */}
        <div class="absolute left-0 inset-y-0 w-1.5 bg-[var(--color-brand-accent)]" aria-hidden="true" />
      </>
    ) : (
      /* ── Original geometric pattern variant ── */
      <>
        <div class="absolute inset-0 opacity-5 pointer-events-none" aria-hidden="true">
          <div class="absolute inset-0" style="background-image: repeating-linear-gradient(45deg, #fff 0, #fff 1px, transparent 0, transparent 50%); background-size: 24px 24px;"></div>
        </div>
        <div class="absolute left-0 inset-y-0 w-1.5 bg-[var(--color-brand-accent)]" />
      </>
    )}

    <div class="relative max-w-6xl mx-auto px-4 py-20 md:py-28 lg:py-36">
      <div class="max-w-3xl">
        <p class="inline-flex items-center gap-2 text-white/80 text-sm font-semibold tracking-widest uppercase mb-6">
          <span class="w-6 h-px bg-[var(--color-brand-accent)] block"></span>
          {HERO_BADGE_HIGHLIGHT ? (<><span class="text-white font-bold">Upshot Solutions</span> — Print · Packaging · Advertising</>) : <>Upshot Solutions — Print · Packaging · Advertising</>}
        </p>
        <h1 class="text-4xl md:text-6xl font-bold leading-[1.1] tracking-tight mb-6">
          Premium Marketing Products,<br />
          <span class="text-white">Delivered Across UAE</span>
        </h1>
        <p class="text-lg md:text-xl text-white/75 max-w-2xl mb-10 leading-relaxed">
          Visiting cards, apparel, branded merchandise, stationery and digital services.
          Fast turnaround, bulk pricing and expert design support — across
          {HERO_CITY_CYCLE ? (
            <span class="city-cycle-wrap" aria-label="Dubai, Abu Dhabi, Sharjah and all seven emirates" role="text">
              <span class="city-cycle-item city-c1">Dubai and all&nbsp;seven emirates.</span>
              <span class="city-cycle-item city-c2">Abu Dhabi and all&nbsp;seven emirates.</span>
              <span class="city-cycle-item city-c3">Sharjah and all&nbsp;seven emirates.</span>
            </span>
          ) : (
            <> Dubai, Abu Dhabi, Sharjah and all seven emirates.</>
          )}
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-[var(--color-brand-charcoal)] font-bold rounded-lg text-base hover:bg-slate-100 transition-colors"
          >
            <!-- WhatsApp icon -->
            <svg class="w-5 h-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L0 24l6.336-1.51A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.817 9.817 0 01-5.002-1.366l-.358-.213-3.762.896.952-3.665-.234-.377A9.818 9.818 0 012.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/>
            </svg>
            Get an Instant Quote
          </a>
          {!BROWSE_IN_TICKER && (
            <a
              href="/print/visiting-cards/dubai-300gsm-gloss"
              class="inline-flex items-center justify-center px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-lg text-base hover:border-white/60 hover:bg-white/5 transition-colors"
            >
              Browse Products
            </a>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- ── Stats / Trust bar ─────────────────────────────────────────────────── -->
  {/*
    When STATS_TYPEWRITER + BROWSE_IN_TICKER are both true the ticker moves
    to just above "We Make" (top of the categories section below), so this
    standalone teal band is not rendered. Otherwise it shows normally.
  */}
  {!(STATS_TYPEWRITER && BROWSE_IN_TICKER) && (
    <section class="bg-[var(--color-brand-charcoal)] text-white" aria-label="Company statistics">
      <div class="max-w-6xl mx-auto px-4 py-8">
        {STATS_TYPEWRITER ? (
          <div class="text-center" aria-live="polite" aria-atomic="true">
            <div class="ticker-wrap" aria-hidden="true">
              <span class="ticker-item">Customised Visiting Cards</span>
              <span class="ticker-item">Logo-Printed T-Shirts</span>
              <span class="ticker-item">Branded Polo Uniforms</span>
              <span class="ticker-item">Premium Business Cards</span>
              <span class="ticker-item">Corporate Gift Sets</span>
              <span class="ticker-item">Exhibition Banners</span>
              <span class="ticker-item">Embroidered Caps</span>
              <span class="ticker-item">Company Letterheads</span>
              <span class="ticker-item">Branded USB Drives</span>
              <span class="ticker-item">Promotional Flyers</span>
              <span class="ticker-item">Custom Tote Bags</span>
              <span class="ticker-item">Office Stationery Kits</span>
            </div>
          </div>
        ) : (
          <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
            {stats.map((s) => (
              <div>
                <dt class="text-3xl font-bold tracking-tight">{s.value}</dt>
                <dd class="text-sm text-white/80 mt-1">{s.label}</dd>
              </div>
            ))}
          </dl>
        )}
      </div>
    </section>
  )}

  <!-- ── Categories ────────────────────────────────────────────────────────── -->
  <section class={`bg-[var(--color-brand-cream)] ${STATS_TYPEWRITER && BROWSE_IN_TICKER ? 'pt-0 pb-16 px-4' : 'py-16 px-4'}`} aria-labelledby="categories-heading">
    {/*
      When the ticker moves here (STATS_TYPEWRITER + BROWSE_IN_TICKER), render a
      full-bleed teal strip at the very top of the cream section — directly below
      the hero, leading the eye straight down into "We Make".
      The -mx-4 cancels the section's px-4 so the strip spans the full width.
    */}
    {STATS_TYPEWRITER && BROWSE_IN_TICKER && (
      <div class="-mx-4 mb-12 bg-[var(--color-brand-charcoal)] text-white">
        <!-- Mobile (< sm): no ticker, full-width centred button -->
        <div class="sm:hidden px-4 py-4 flex justify-center">
          <a
            href="/products"
            class="inline-flex items-center gap-2 px-5 py-2.5 border-2 border-white/50 text-white font-semibold rounded-full text-sm hover:border-white hover:bg-white/10 transition-colors"
          >
            Browse Products
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5"/></svg>
          </a>
        </div>
        <!-- Desktop (≥ sm): ticker fills band, button at right edge -->
        <div class="hidden sm:flex max-w-6xl mx-auto px-4 py-5 relative items-center justify-end" aria-live="polite" aria-atomic="true">
          <div style="position:absolute;inset:0;overflow:hidden;pointer-events:none;" aria-hidden="true">
            <div class="ticker-wrap" style="position:static;height:100%;">
              <span class="ticker-item">Customised Visiting Cards</span>
              <span class="ticker-item">Logo-Printed T-Shirts</span>
              <span class="ticker-item">Branded Polo Uniforms</span>
              <span class="ticker-item">Premium Business Cards</span>
              <span class="ticker-item">Corporate Gift Sets</span>
              <span class="ticker-item">Exhibition Banners</span>
              <span class="ticker-item">Embroidered Caps</span>
              <span class="ticker-item">Company Letterheads</span>
              <span class="ticker-item">Branded USB Drives</span>
              <span class="ticker-item">Promotional Flyers</span>
              <span class="ticker-item">Custom Tote Bags</span>
              <span class="ticker-item">Office Stationery Kits</span>
            </div>
          </div>
          <a
            href="/products"
            class="relative z-10 shrink-0 inline-flex items-center gap-2 px-5 py-2.5 border-2 border-white/50 text-white font-semibold rounded-full text-sm hover:border-white hover:bg-white/10 transition-colors whitespace-nowrap"
          >
            Browse Products
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 10h12M11 5l5 5-5 5"/></svg>
          </a>
        </div>
      </div>
    )}
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-10">
        <h2 id="categories-heading" class="text-3xl md:text-4xl font-bold mb-3">We Make</h2>
        <p class="text-[var(--color-brand-charcoal-light)] max-w-xl mx-auto">
          From a single business card to a full trade-show kit — we handle every print and branding need.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {categories.map((cat) => (
          CATEGORY_PHOTO_CARDS ? (
            // ── Photo card ──────────────────────────────────────────────────
            <a
              href={cat.href}
              class="group relative overflow-hidden rounded-xl aspect-[4/3] flex items-end shadow-md hover:shadow-xl transition-shadow duration-300"
            >
              <div
                class="absolute inset-0 bg-cover bg-center transition-transform duration-500 ease-out group-hover:scale-105"
                style={`background-image: url('${cat.image}')`}
              ></div>
              <div class="absolute inset-0 bg-gradient-to-t from-black/75 via-black/35 to-black/10"></div>
              <div class="absolute bottom-0 left-0 h-0.5 w-0 bg-[var(--color-brand-accent)] group-hover:w-full transition-all duration-400"></div>
              <div class="relative p-5">
                <h3 class="font-bold text-base text-white mb-1 leading-snug">{cat.label}</h3>
                <p class="text-sm text-white/70 leading-relaxed">{cat.desc}</p>
              </div>
            </a>
          ) : (
            // ── Icon card ───────────────────────────────────────────────────
            <a
              href={cat.href}
              class="group bg-white rounded-xl p-6 border border-slate-100 hover:border-[var(--color-brand-charcoal)] hover:shadow-[var(--shadow-card-hover)] transition-all"
            >
              <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4 text-[var(--color-brand-charcoal)]" style="background-color: rgba(11, 31, 59, 0.08);" set:html={cat.icon} />
              <h3 class="font-bold text-lg mb-2 group-hover:text-[var(--color-brand-charcoal)] transition-colors">{cat.label}</h3>
              <p class="text-sm text-[var(--color-brand-charcoal-light)] leading-relaxed">{cat.desc}</p>
            </a>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- ── Featured products ─────────────────────────────────────────────────── -->
  {featured.length > 0 && (
    <section class="py-16 px-4 bg-white" aria-labelledby="featured-heading">
      <div class="max-w-6xl mx-auto">
        <div class="flex items-end justify-between mb-10 gap-4 flex-wrap">
          <div>
            <h2 id="featured-heading" class="text-3xl md:text-4xl font-bold mb-2">Popular in Dubai</h2>
            <p class="text-[var(--color-brand-charcoal-light)]">Our most-ordered products — ready for fast dispatch.</p>
          </div>
          <a
            href="/print"
            class="shrink-0 text-sm font-semibold text-[var(--color-brand-charcoal)] hover:underline"
          >
            View all products →
          </a>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featured.map((p) => {
            const href = `/${p.data.category}/${p.data.product}/${p.data.page_slug}`;
            return (
              <a
                href={href}
                class="group bg-white rounded-xl border border-slate-100 hover:border-[var(--color-brand-charcoal)] hover:shadow-[var(--shadow-card-hover)] transition-all overflow-hidden"
              >
                <!-- Colour band -->
                <div class="h-2 bg-[var(--color-brand-charcoal)]"></div>
                <div class="p-5">
                  <p class="text-xs font-semibold text-[var(--color-brand-charcoal-light)] uppercase tracking-wider mb-2">
                    {p.data.product_details.city} · {p.data.product_details.variant}
                  </p>
                  <h3 class="font-bold text-base mb-1 group-hover:text-[var(--color-brand-charcoal)] transition-colors leading-snug">
                    {p.data.hero.headline}
                  </h3>
                  <p class="text-sm text-[var(--color-brand-charcoal-light)] mb-4 line-clamp-2">
                    {p.data.hero.subline}
                  </p>
                  <div class="flex items-center justify-between">
                    <span class="text-[var(--color-brand-charcoal)] font-bold text-lg">
                      From {p.data.product_details.currency} {p.data.product_details.price_from}
                    </span>
                    <span class="text-xs bg-green-50 text-green-700 border border-green-200 rounded-full px-2 py-0.5 font-medium">
                      {p.data.product_details.turnaround}
                    </span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- ── Process strip ─────────────────────────────────────────────────────── -->
  <section class="bg-[var(--color-brand-cream-dark)] py-14 px-4" aria-labelledby="process-heading">
    <div class="max-w-6xl mx-auto">
      <h2 id="process-heading" class="text-2xl font-bold text-center mb-12">How It Works</h2>

      {HOW_IT_WORKS_FLOW ? (
        /* ── Flow diagram variant ── */
        <div class="flex flex-col md:flex-row md:items-start">

          <!-- Step 01 -->
          <div class="flex-1 flex flex-col items-center text-center px-4">
            <div class="w-14 h-14 rounded-full bg-[var(--color-brand-charcoal)] text-white flex items-center justify-center font-black text-lg shadow-md mb-4" aria-hidden="true">01</div>
            <h3 class="font-bold text-sm mb-2">Request a Quote</h3>
            <p class="text-xs text-[var(--color-brand-charcoal-light)] leading-relaxed max-w-[180px]">Chat with us on WhatsApp or fill in our form — we respond in minutes.</p>
          </div>

          <!-- Arrow 1→2 -->
          <div class="hidden md:flex items-center justify-center shrink-0 text-slate-300">
            <svg width="72" height="28" viewBox="0 0 72 28" fill="none" aria-hidden="true">
              <defs>
                <marker id="ah-d1" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto" markerUnits="userSpaceOnUse">
                  <polygon points="0 0, 8 3, 0 6" fill="currentColor"/>
                </marker>
              </defs>
              <path d="M5 19 Q36 4 63 17" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 3" stroke-linecap="round" fill="none" marker-end="url(#ah-d1)"/>
            </svg>
          </div>
          <div class="md:hidden flex justify-center py-2 text-slate-300">
            <svg width="28" height="52" viewBox="0 0 28 52" fill="none" aria-hidden="true">
              <defs>
                <marker id="ah-m1" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto" markerUnits="userSpaceOnUse">
                  <polygon points="0 0, 8 3, 0 6" fill="currentColor"/>
                </marker>
              </defs>
              <path d="M14 5 Q22 26 14 47" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 3" stroke-linecap="round" fill="none" marker-end="url(#ah-m1)"/>
            </svg>
          </div>

          <!-- Step 02 -->
          <div class="flex-1 flex flex-col items-center text-center px-4">
            <div class="w-14 h-14 rounded-full bg-[var(--color-brand-charcoal)] text-white flex items-center justify-center font-black text-lg shadow-md mb-4" aria-hidden="true">02</div>
