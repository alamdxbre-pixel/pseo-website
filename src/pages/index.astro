---
import Base from '@/layouts/Base.astro';
import { buildWhatsAppLink } from '@/lib/utils';

const phone = import.meta.env.WHATSAPP_NUMBER ?? '97152895506';
const waHref = buildWhatsAppLink(phone, "Hi, I'd like to discuss an AI engineering engagement.");
const siteUrl = import.meta.env.SITE ?? '';

const services = [
  {
    num: '01',
    id: 'it-consultancy',
    title: 'IT Consultancy',
    brief: 'Strategic technology advisory that translates business objectives into executable engineering roadmaps — architecture decisions, vendor selection, and governance frameworks included.',
    scope: ['Technology strategy', 'Architecture review', 'Vendor selection', 'IT governance', 'Digital transformation', 'Risk assessment'],
  },
  {
    num: '02',
    id: 'custom-software-engineering',
    title: 'Custom Software Engineering',
    brief: 'Purpose-built systems designed for correctness, performance, and longevity — not speed-to-demo.',
    scope: ['Web platforms', 'APIs & integrations', 'Backend systems', 'Mobile', 'DevOps'],
  },
  {
    num: '03',
    id: 'microservice-architecture',
    title: 'Microservice Architecture',
    brief: 'Domain-driven service decomposition with the infrastructure discipline to operate it at enterprise scale.',
    scope: ['Event streaming', 'Service mesh', 'Kubernetes', 'CI/CD pipelines', 'Observability'],
  },
  {
    num: '04',
    id: 'saas-platform-engineering',
    title: 'SaaS Platform Engineering',
    brief: 'Multi-tenant infrastructure built to compliance, security, and uptime standards from the first sprint.',
    scope: ['Multi-tenancy', 'Billing systems', 'RBAC', 'Audit trails', 'SOC 2 readiness'],
  },
  {
    num: '05',
    id: 'rag-knowledge-systems',
    title: 'RAG & Knowledge Systems',
    brief: 'Enterprise-grade Retrieval-Augmented Generation — grounded in your data, traceable, hallucination-resistant.',
    scope: ['Vector search', 'LLM integration', 'Document pipelines', 'Source attribution', 'Evaluation'],
  },
  {
    num: '06',
    id: 'ai-model-training',
    title: 'AI Model Training & Fine-tuning',
    brief: 'Domain-adapted models with the evaluation rigour and MLOps tooling to deploy and maintain them reliably.',
    scope: ['Instruction tuning', 'RLHF / DPO', 'Dataset curation', 'Evaluation', 'MLOps'],
  },
];

const metrics = [
  { value: '35+',  label: 'Years combined experience', sub: 'Senior engineers on every engagement' },
  { value: '48h',  label: 'To written proposal',       sub: 'From your first conversation with us' },
  { value: '100%', label: 'Code ownership',            sub: 'Transferred to you at every milestone' },
  { value: '1',    label: 'Point of contact',           sub: 'One senior engineer owns your engagement end-to-end — no rotating account managers' },
];

const differentiators = [
  {
    title: 'We build what we recommend.',
    body: 'Our consultancy and our engineering are the same team. Every architecture decision, technology choice, and strategy we advise on — we are the people who will build, deliver, and stand behind it.',
  },
  {
    title: 'Full IP transfer. No lock-in.',
    body: 'You receive every line of source code, model weights, infrastructure definitions, and documentation. We build for your long-term independence, not our recurring revenue.',
  },
  {
    title: 'Enterprise-ready by design.',
    body: 'Security architecture, audit logging, access controls, and compliance readiness are designed at the architecture phase — never retrofitted after a procurement or risk review.',
  },
];

const process = [
  {
    step: '01',
    title: 'Technical Discovery',
    desc: 'Structured sessions mapping requirements, constraints, existing infrastructure, and measurable success criteria.',
  },
  {
    step: '02',
    title: 'Architecture & Proposal',
    desc: 'A written proposal: stack decisions, system design, delivery timeline, milestones, and a risk register.',
  },
  {
    step: '03',
    title: 'Agile Delivery',
    desc: 'Sprint-based development. Weekly demos, continuous integration, shared tracking, full decision documentation.',
  },
  {
    step: '04',
    title: 'Handover & Operate',
    desc: 'Production deployment, runbook authoring, and structured handover — or an ongoing engineering retainer.',
  },
];
---

<Base
  title="Enterprise Technology & AI Solutions; Marketing & Advertising | BuoyantSolutions"
  description="IT consultancy, custom software, microservices, SaaS platforms, and AI systems for organisations that cannot afford to fail. UAE and global."
  canonical="/"
  og={{
    title: 'Enterprise Technology & AI Solutions; Marketing & Advertising | BuoyantSolutions',
    description: 'AI systems built for the world\'s most demanding organisations.',
    type: 'website',
    image_width: 1200,
    image_height: 630,
  }}
>

<!-- ════════════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════════ -->
<section class="relative min-h-screen flex flex-col justify-center bg-[#030B18] text-white overflow-hidden">

  <!-- Dot grid -->
  <div class="absolute inset-0 ob-dot-grid pointer-events-none" aria-hidden="true"></div>

  <!-- Right glow -->
  <div class="ob-glow-right" aria-hidden="true"></div>

  <!-- Bottom fade into next section -->
  <div
    class="absolute bottom-0 inset-x-0 h-40 pointer-events-none"
    style="background: linear-gradient(to top, #030B18 0%, transparent 100%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-7xl mx-auto w-full px-6 sm:px-10 lg:px-16 py-32 lg:py-44">

    <!-- Overline -->
    <div class="flex items-center gap-4 mb-12">
      <span class="w-12 h-px bg-blue-400 shrink-0" aria-hidden="true"></span>
      <p class="ob-overline">Enterprise Technology &amp; AI Solutions &nbsp;·&nbsp; UAE &amp; Global</p>
    </div>

    <!-- Headline -->
    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-[1.05] tracking-[-0.03em] mb-8 max-w-3xl">
      Enterprise Technology &amp; AI —<br />
      <span class="text-blue-400">Engineered to Enterprise Standard.</span>
    </h1>

    <!-- Body -->
    <p class="text-base text-slate-400 max-w-xl leading-relaxed mb-12">
      From IT strategy and custom software to AI pipelines and fine-tuned models — end-to-end technology delivery for enterprises where reliability, security, and precision are non-negotiable.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-5">
      <a
        href="/contact"
        class="inline-flex items-center gap-2 px-8 py-4 bg-blue-500 text-white text-sm font-bold tracking-wide rounded hover:bg-blue-600 transition-colors"
      >
        Get in Touch
        <svg class="w-4 h-4 shrink-0" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <a
        href="/services/it-ai"
        class="text-sm font-medium text-slate-500 hover:text-slate-300 transition-colors"
      >
        View capabilities &rarr;
      </a>
    </div>
  </div>

  <!-- Bottom thin rule -->
  <div class="absolute bottom-0 inset-x-0 ob-rule" aria-hidden="true"></div>
</section>


<!-- ════════════════════════════════════════════════════════
     SERVICES
════════════════════════════════════════════════════════ -->
<section class="bg-white py-24 sm:py-32 px-6 sm:px-10 lg:px-16" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto">

    <!-- Section label -->
    <div class="flex items-center gap-4 mb-14">
      <span class="w-8 h-px bg-blue-500 shrink-0" aria-hidden="true"></span>
      <p class="ob-overline" style="color:#3B82F6">Capabilities</p>
    </div>

    <h2 id="services-heading" class="text-4xl sm:text-5xl font-extrabold tracking-[-0.03em] text-slate-900 mb-20">
      Our Services
    </h2>

    <!-- Service rows -->
    <div class="divide-y divide-slate-100">
      {services.map((svc) => (
        <a
          href={`/services/it-ai#${svc.id}`}
          class="group grid md:grid-cols-[72px_1fr_32px] gap-6 md:gap-10 py-10 -mx-6 px-6 hover:bg-slate-50 transition-colors"
        >
          <!-- Number -->
          <div class="pt-0.5">
            <span class="font-mono text-sm font-bold text-blue-400">{svc.num}</span>
          </div>

          <!-- Content -->
          <div>
            <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-600 transition-colors leading-snug">
              {svc.title}
            </h3>
            <p class="text-slate-500 text-sm leading-relaxed mb-5 max-w-2xl">{svc.brief}</p>
            <div class="flex flex-wrap gap-2">
              {svc.scope.map((tag) => (
                <span class="text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 bg-slate-100 text-slate-400 rounded">
                  {tag}
                </span>
              ))}
            </div>
          </div>

          <!-- Arrow -->
          <div class="hidden md:flex items-start pt-1">
            <svg
              class="w-5 h-5 text-slate-200 group-hover:text-blue-400 group-hover:translate-x-1 transition-all"
              viewBox="0 0 20 20"
              fill="currentColor"
              aria-hidden="true"
            >
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════════════════════
     METRICS
════════════════════════════════════════════════════════ -->
<section class="bg-[#030B18] py-20 px-6 sm:px-10 lg:px-16" aria-label="Company metrics">
  <div class="max-w-7xl mx-auto">
    <dl class="grid sm:grid-cols-2 lg:grid-cols-4">
      {metrics.map((m, i) => (
        <div class={`py-10 lg:py-12 ${i > 0 ? 'lg:border-l lg:border-white/[0.07] lg:pl-12' : ''} ${i > 0 && i < 2 ? 'sm:border-l sm:border-white/[0.07] sm:pl-12' : ''}`}>
          <dt class="text-5xl font-extrabold tracking-[-0.04em] text-white mb-2">{m.value}</dt>
          <dd class="text-sm font-semibold text-slate-400 mb-1">{m.label}</dd>
          <dd class="text-xs text-slate-600">{m.sub}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>


<!-- ════════════════════════════════════════════════════════
     DIFFERENTIATORS
════════════════════════════════════════════════════════ -->
<section class="bg-white py-24 sm:py-32 px-6 sm:px-10 lg:px-16" aria-labelledby="diff-heading">
  <div class="max-w-7xl mx-auto">

    <div class="flex items-center gap-4 mb-14">
      <span class="w-8 h-px bg-blue-500 shrink-0" aria-hidden="true"></span>
      <p class="ob-overline" style="color:#3B82F6">Why BuoyantSolutions</p>
    </div>

    <h2 id="diff-heading" class="text-4xl sm:text-5xl font-extrabold tracking-[-0.03em] text-slate-900 mb-20">
      How We're Different
    </h2>

    <div class="grid md:grid-cols-3 gap-12 lg:gap-20">
      {differentiators.map((d, i) => (
        <div>
          <span class="font-mono text-xs font-bold text-blue-400 block mb-8">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="text-xl font-bold text-slate-900 mb-5 leading-snug">{d.title}</h3>
          <p class="text-slate-500 leading-relaxed">{d.body}</p>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════════════════════
     PROCESS
════════════════════════════════════════════════════════ -->
<section class="bg-[#060F22] py-24 sm:py-32 px-6 sm:px-10 lg:px-16 text-white" aria-labelledby="process-heading">
  <div class="max-w-7xl mx-auto">

    <div class="flex items-center gap-4 mb-14">
      <span class="w-8 h-px bg-blue-400 shrink-0" aria-hidden="true"></span>
      <p class="ob-overline">Engagement Model</p>
    </div>

    <h2 id="process-heading" class="text-4xl sm:text-5xl font-extrabold tracking-[-0.03em] mb-20">
      How We Engage
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8">
      {process.map((p) => (
        <div>
          <div class="w-full h-px bg-blue-500/20 mb-8" aria-hidden="true"></div>
          <span class="font-mono text-xs font-bold text-blue-400 block mb-5">{p.step}</span>
          <h3 class="font-bold text-base text-white mb-3 leading-snug">{p.title}</h3>
          <p class="text-sm text-slate-500 leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>


<!-- ════════════════════════════════════════════════════════
     CTA
════════════════════════════════════════════════════════ -->
<section class="relative bg-[#030B18] py-32 px-6 sm:px-10 lg:px-16 text-center overflow-hidden" aria-labelledby="cta-heading">

  <!-- Centered glow -->
  <div class="ob-glow-center" aria-hidden="true"></div>

  <!-- Top rule -->
  <div class="absolute top-0 inset-x-0 ob-rule" aria-hidden="true"></div>

  <div class="relative max-w-2xl mx-auto">
    <p class="ob-overline mb-10 block">Ready to begin?</p>

    <h2 id="cta-heading" class="text-4xl sm:text-5xl font-extrabold tracking-[-0.03em] text-white mb-8 leading-tight">
      Let's Discuss Your<br />Engineering Challenge.
    </h2>

    <p class="text-slate-400 text-lg mb-12 leading-relaxed">
      Share your requirements. We respond with a technical assessment within 48 hours.<br class="hidden sm:block" />
      No sales calls. No demos. Just engineering.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-2 px-10 py-4 bg-blue-500 text-white font-bold text-sm tracking-wide rounded hover:bg-blue-600 transition-colors"
      >
        Get in Touch
      </a>
      <a
        href={waHref}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center px-10 py-4 border border-white/10 text-slate-400 font-medium text-sm rounded hover:border-white/20 hover:text-slate-200 transition-colors"
      >
        WhatsApp Us
      </a>
    </div>
  </div>
</section>


<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "BuoyantSolutions",
  "description": "Enterprise AI engineering — RAG systems, SaaS platforms, microservices, and AI model training for global organisations.",
  "url": siteUrl,
  "areaServed": ["UAE", "GCC", "Global"],
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "AE",
    "addressRegion": "Dubai"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": ["English", "Arabic"]
  }
})} />

</Base>
