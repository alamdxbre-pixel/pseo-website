---
import Base from '../layouts/Base.astro';
---

<Base>
  <section class="min-h-screen flex flex-col items-center justify-center gap-6 px-4 text-center">
    <h1 class="text-5xl font-bold text-[var(--color-brand-charcoal)] tracking-tight">
      Premium Marketing Products<br />
      <span class="text-[var(--color-brand-accent)]">Across UAE & GCC</span>
    </h1>
    <p class="text-xl text-[var(--color-brand-charcoal-light)] max-w-2xl">
      Visiting cards, T-shirts, caps, merchandise, office stationery and digital
      services — delivered fast across Dubai, Abu Dhabi, Sharjah and beyond.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 mt-4">
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-3 rounded-lg bg-[var(--color-brand-accent)] text-white font-semibold hover:bg-[var(--color-brand-accent-dark)] transition-colors"
      >
        Get an Instant Quote
      </a>
      <a
        href="/print"
        class="inline-flex items-center justify-center px-8 py-3 rounded-lg border-2 border-[var(--color-brand-accent)] text-[var(--color-brand-accent)] font-semibold hover:bg-[var(--color-brand-cream)] transition-colors"
      >
        View Products
      </a>
    </div>
    <p class="text-sm text-[var(--color-brand-charcoal-light)] mt-8">
      Full site launching soon — built with Astro + Cloudflare Pages
    </p>
  </section>
</Base>
