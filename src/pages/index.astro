<style>
  /* ── Typewriter ticker ────────────────────────────────────────────────────
     12 items × ~3 s each = 36 s total cycle.
     Each item fades in, holds, then fades out via CSS steps animation.
  ──────────────────────────────────────────────────────────────────────── */
  .ticker-wrap {
    display: block;
    height: 2.25rem;          /* fixed height so layout doesn't jump */
    position: relative;
    overflow: hidden;
  }

  .ticker-item {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: -0.01em;
    opacity: 0;
    animation: ticker-fade 36s linear infinite;
  }

  /* Stagger each item by 3 s (36 s / 12 items) */
  .ticker-item:nth-child(1)  { animation-delay:  0s; }
  .ticker-item:nth-child(2)  { animation-delay:  3s; }
  .ticker-item:nth-child(3)  { animation-delay:  6s; }
  .ticker-item:nth-child(4)  { animation-delay:  9s; }
  .ticker-item:nth-child(5)  { animation-delay: 12s; }
  .ticker-item:nth-child(6)  { animation-delay: 15s; }
  .ticker-item:nth-child(7)  { animation-delay: 18s; }
  .ticker-item:nth-child(8)  { animation-delay: 21s; }
  .ticker-item:nth-child(9)  { animation-delay: 24s; }
  .ticker-item:nth-child(10) { animation-delay: 27s; }
  .ticker-item:nth-child(11) { animation-delay: 30s; }
  .ticker-item:nth-child(12) { animation-delay: 33s; }

  @keyframes ticker-fade {
    /* Each item occupies 1/12 of the cycle (8.33%).
       Slides in from right, holds, then exits left */
    0%      { opacity: 0;   transform: translateX(60px); }
    1.5%    { opacity: 1;   transform: translateX(0);    }
    6.5%    { opacity: 1;   transform: translateX(0);    }
    8.33%   { opacity: 0;   transform: translateX(-60px);}
    100%    { opacity: 0;   transform: translateX(-60px);}
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-item { animation: none; transform: none; }
    .ticker-item:nth-child(1) { opacity: 1; position: static; }
  }

  /* ── Hero city cycling ── */
  /*
    inline-grid stacks all three city items in the same grid cell.
    The wrapper width = widest item ("Abu Dhabi and all seven emirates.").
    City names are left-aligned; trailing copy is inside each item so
    there is no gap between the city name and "and all seven emirates".
  */
  .city-cycle-wrap {
    display: inline-grid;
    vertical-align: bottom;
  }
  .city-cycle-item {
    grid-column: 1;
    grid-row: 1;
    white-space: nowrap;
    color: white;
    font-weight: 600;
    opacity: 0;
    animation: city-fade 9s ease-in-out infinite;
  }
  .city-c1 { animation-delay: 0s; }
  .city-c2 { animation-delay: 3s; }
  .city-c3 { animation-delay: 6s; }

  @keyframes city-fade {
    /*
      3 cities × 3 s each = 9 s cycle.
      Fade in 0.6 s → hold 1.8 s → fade out 0.6 s.
    */
    0%      { opacity: 0; }
    6.67%   { opacity: 1; }   /* 0.6 s in  */
    26.67%  { opacity: 1; }   /* hold until 2.4 s */
    33.33%  { opacity: 0; }   /* 3 s mark  */
    100%    { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .city-cycle-item { animation: none; opacity: 0; }
    .city-c1 { opacity: 1; position: static; }
  }
</style>

