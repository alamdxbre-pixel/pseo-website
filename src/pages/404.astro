---
// 404 page
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found | pseo-website">
  <section class="min-h-screen flex flex-col items-center justify-center gap-4 px-4 text-center">
    <p class="text-6xl font-bold text-[var(--color-brand-accent)]">404</p>
    <h1 class="text-2xl font-semibold text-[var(--color-brand-charcoal)]">Page not found</h1>
    <p class="text-[var(--color-brand-charcoal-light)]">
      The page you are looking for does not exist or has been moved.
    </p>
    <a
      href="/"
      class="mt-4 inline-flex items-center justify-center px-6 py-2 rounded-lg bg-[var(--color-brand-accent)] text-white font-medium hover:bg-[var(--color-brand-accent-dark)] transition-colors"
    >
      Back to Home
    </a>
  </section>
</Base>
