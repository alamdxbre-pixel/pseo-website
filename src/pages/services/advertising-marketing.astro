---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import { buildWhatsAppLink } from '@/lib/utils';

const siteUrl = import.meta.env.SITE ?? '';
const canonical = `${siteUrl}/services/advertising-marketing`;
const whatsappNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER || '971500000000';
const whatsappMessage = buildWhatsAppLink(whatsappNumber, 'Hi, I would like to discuss advertising and marketing services.');

// Pull all published products for the services grid
const allProducts = await getCollection('products', ({ data }) => data.published);

// Group by category
const byCategory: Record<string, typeof allProducts> = {};
for (const p of allProducts) {
  const cat = p.data.category ?? 'print';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(p);
}

const categoryMeta: Record<string, { label: string; icon: string; description: string }> = {
  print: {
    label: 'Print & Stationery',
    icon: '🖨️',
    description: 'Visiting cards, stationery, banners',
  },
  apparel: {
    label: 'Apparel & Uniforms',
    icon: '👕',
    description: 'T-shirts, caps, uniforms',
  },
  merchandise: {
    label: 'Branded Merchandise & Gifts',
    icon: '🎁',
    description: 'Branded gifts, promotional items',
  },
  digital: {
    label: 'Digital Services',
    icon: '💻',
    description: 'Design, print-ready files, packaging',
  },
};

const services = [
  {
    id: 'campaigns',
    title: 'Campaign Management',
    description: 'Strategic advertising campaigns from concept to execution. We handle creative strategy, media planning, and performance tracking.',
    icon: '📊',
    highlights: [
      'Creative concept development',
      'Media buying & placement',
      'Campaign execution & management',
      'Performance analytics & optimization',
      'Multi-channel coordination',
      'ROI tracking',
    ],
  },
  {
    id: 'digital',
    title: 'Digital Marketing',
    description: 'Online marketing strategies to reach and engage your target audience where they spend their time.',
    icon: '💡',
    highlights: [
      'Search engine optimization (SEO)',
      'Social media marketing & management',
      'Paid advertising (Google, Meta, LinkedIn)',
      'Email marketing campaigns',
      'Content strategy & creation',
      'Web analytics & reporting',
    ],
  },
  {
    id: 'print',
    title: 'Print & Direct Marketing',
    description: 'Tangible marketing materials that leave lasting impressions. From business cards to large-format campaigns.',
    icon: '📄',
    highlights: [
      'Brochures & catalogs',
      'Flyers & posters',
      'Visiting cards & stationery',
      'Direct mail campaigns',
      'Promotional materials',
      'Large-format printing',
    ],
  },
  {
    id: 'branding',
    title: 'Corporate Branding & Merchandise',
    description: 'Branded items that strengthen your company identity and create lasting impressions with clients and employees.',
    icon: '🎁',
    highlights: [
      'Corporate uniforms & apparel',
      'Branded merchandise & giveaways',
      'Employee recognition items',
      'Client gift packages',
      'Event promotional items',
      'Brand consistency guidelines',
    ],
  },
];

// Featured case studies
const caseStudies = [
  {
    client: 'Regional Bank — UAE National Day Campaign',
    category: 'print',
    description: '50,000 branded folders, 30,000 visiting cards and 5,000 custom notebooks delivered across 7 emirates in 4 days.',
    stat: '50,000+ units',
    icon: '🏦',
  },
  {
    client: 'Hospitality Group — Staff Uniform Rollout',
    category: 'apparel',
    description: 'Full uniform programme for 800 staff across 12 hotel properties — embroidered polos, caps and aprons in three colourways.',
    stat: '800 staff',
    icon: '🏨',
  },
  {
    client: 'Tech Startup — GITEX Giveaway Pack',
    category: 'merchandise',
    description: 'Custom-branded power banks, tote bags and stickers for a GITEX launch stand. Designed, produced and delivered in 10 days.',
    stat: '3,000 packs',
    icon: '💡',
  },
  {
    client: 'Real Estate Developer — Digital Brand Refresh',
    category: 'digital',
    description: 'Full suite of editable social media templates, email signatures and digital brochures aligned to new brand guidelines.',
    stat: '120+ assets',
    icon: '🏢',
  },
];

// Precompute sections for template
type ProductEntry = typeof allProducts[number];
type Section = { cat: string; meta: { label: string; icon: string; description: string }; products: ProductEntry[] };

const sections: Section[] = Object.entries(byCategory)
  .map(([cat, products]) => {
    const meta = categoryMeta[cat];
    if (!meta) return null;
    const seen = new Set<string>();
    const deduped = products.filter((p) => {
      if (seen.has(p.data.title)) return false;
      seen.add(p.data.title);
      return true;
    });
    return { cat, meta, products: deduped.slice(0, 6) };
  })
  .filter(Boolean) as Section[];
---

<Base
  title="Advertising & Marketing Services — UAE"
  description="Complete advertising and marketing solutions for UAE businesses. Campaigns, digital marketing, print materials, and branded merchandise from Dubai and Abu Dhabi."
  canonical={canonical}
  og={{
    title: 'Advertising & Marketing Services',
    description: 'Real work for real UAE clients — from 50,000-unit campaigns to boutique brand launches.',
    image: '/images/og/services.png',
    type: 'website',
  }}
>
  <!-- Hero -->
  <section class="bg-[var(--color-brand-charcoal)] text-white">
    <div class="max-w-5xl mx-auto px-4 py-20 sm:py-28">
      <div class="border-l-4 border-[var(--color-brand-accent)] pl-6">
        <p class="text-sm uppercase tracking-widest text-[var(--color-brand-accent)] mb-3 font-semibold">Marketing Excellence</p>
        <h1 class="text-4xl sm:text-5xl font-extrabold leading-tight mb-6">
          Advertising &<br />
          <span class="text-[var(--color-brand-accent)]">Marketing Services</span>
        </h1>
        <p class="text-lg text-gray-300 max-w-2xl">
          Over 50,000 projects delivered since 2014. We create campaigns, brands, and marketing materials that drive business growth.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="max-w-5xl mx-auto px-4 py-16 sm:py-20">
    <h2 class="text-3xl font-bold text-center mb-12">What We Offer</h2>
    <div class="grid sm:grid-cols-2 gap-8">
      {services.map((service) => (
        <div
          id={service.id}
          class="bg-white rounded-xl border border-gray-200 hover:border-[var(--color-brand-accent)] hover:shadow-md transition-all p-8 scroll-mt-24"
        >
          <!-- Icon -->
          <div class="text-4xl mb-4">{service.icon}</div>

          <!-- Title -->
          <h3 class="text-xl font-bold mb-3 text-slate-900">{service.title}</h3>

          <!-- Description -->
          <p class="text-gray-700 mb-6">{service.description}</p>

          <!-- Highlights -->
          <ul class="space-y-2 mb-6">
            {service.highlights.map((highlight) => (
              <li class="flex items-start gap-2 text-sm">
                <span class="text-[var(--color-brand-accent)] font-bold mt-0.5">•</span>
                <span class="text-gray-700">{highlight}</span>
              </li>
            ))}
          </ul>

          <!-- CTA -->
          <a
            href={whatsappMessage}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-brand-accent)]/10 hover:bg-[var(--color-brand-accent)]/20 text-[var(--color-brand-accent)] font-semibold rounded-lg transition-colors text-sm"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004c-1.462 0-2.846-.356-4.027-1.03l-.289-.145-2.979.784.8-2.906-.187-.3A6.471 6.471 0 015.093 2c3.59 0 6.514 2.88 6.514 6.411 0 1.762-.614 3.44-1.748 4.778l-.213.262.857 2.948-3.054-.784.276.208c1.052.652 2.271 1.004 3.582 1.004 3.59 0 6.514-2.88 6.514-6.411S15.07 6.979 11.481 6.979z"/>
            </svg>
            Get a Quote
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Product categories overview -->
  <section class="bg-[var(--color-brand-cream)] py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">Production Capabilities</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {Object.entries(categoryMeta).map(([slug, meta]) => (
          <div class="bg-white rounded-xl border border-gray-200 p-6 hover:border-[var(--color-brand-accent)] hover:shadow-md transition-all text-center">
            <p class="text-4xl mb-4">{meta.icon}</p>
            <h3 class="font-bold text-base mb-2">{meta.label}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{meta.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Live products from content collection -->
  {sections.map(({ cat: _cat, meta, products }) => (
    <section class="bg-white py-14">
      <div class="max-w-5xl mx-auto px-4">
        <div class="flex items-center gap-3 mb-8">
          <span class="text-3xl">{meta.icon}</span>
          <h2 class="text-2xl font-bold">{meta.label}</h2>
        </div>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">
          {products.map((p) => (
            <a
              href={`/${p.data.category}/${p.id.split('/').slice(-2, -1)[0]}/${p.data.page_slug}`}
              class="block bg-[var(--color-brand-cream)] rounded-xl border border-gray-200 hover:border-[var(--color-brand-accent)] hover:shadow-md transition-all overflow-hidden group"
            >
              <div class="h-36 bg-gradient-to-br from-[var(--color-brand-accent)]/10 to-[var(--color-brand-accent)]/5 flex items-center justify-center">
                <span class="text-5xl">{meta.icon}</span>
              </div>
              <div class="p-5">
                <h3 class="font-bold text-base mb-1 group-hover:text-[var(--color-brand-accent)] transition-colors">
                  {p.data.title}
                </h3>
                <p class="text-xs text-gray-500 mb-3">{p.data.product_details.city} · from AED {p.data.product_details.price_from}</p>
                <span class="text-xs font-semibold text-[var(--color-brand-accent)]">View details →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ))}

  <!-- Case studies -->
  <section class="max-w-5xl mx-auto px-4 py-16 sm:py-20">
    <h2 class="text-3xl font-bold text-center mb-4">Client Highlights</h2>
    <p class="text-center text-gray-600 mb-12 max-w-xl mx-auto">
      A selection of projects we're proud of — from large-scale campaigns to boutique brand launches.
    </p>
    <div class="grid sm:grid-cols-2 gap-8">
      {caseStudies.map((cs) => (
        <div class="rounded-xl border border-gray-200 p-8 hover:border-[var(--color-brand-accent)] hover:shadow-md transition-all">
          <div class="flex items-start gap-4 mb-4">
            <span class="text-4xl">{cs.icon}</span>
            <div>
              <p class="font-bold text-base leading-snug">{cs.client}</p>
              <span class="inline-block mt-1 text-xs font-semibold uppercase tracking-wide bg-[var(--color-brand-accent)]/10 text-[var(--color-brand-accent)] px-2 py-0.5 rounded">
                {categoryMeta[cs.category]?.label ?? cs.category}
              </span>
            </div>
          </div>
          <p class="text-gray-700 text-sm leading-relaxed mb-4">{cs.description}</p>
          <p class="text-xl font-extrabold text-[var(--color-brand-accent)]">{cs.stat}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-[var(--color-brand-charcoal)] text-white py-16">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold mb-4">Ready to Launch Your Campaign?</h2>
      <p class="text-gray-300 mb-8">Tell us what you need and we'll send a tailored proposal within the hour.</p>
      <a
        href={whatsappMessage}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 bg-[var(--color-brand-accent)] hover:bg-[var(--color-brand-accent)]/90 text-white font-semibold px-8 py-4 rounded-lg transition-all text-lg"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004c-1.462 0-2.846-.356-4.027-1.03l-.289-.145-2.979.784.8-2.906-.187-.3A6.471 6.471 0 015.093 2c3.59 0 6.514 2.88 6.514 6.411 0 1.762-.614 3.44-1.748 4.778l-.213.262.857 2.948-3.054-.784.276.208c1.052.652 2.271 1.004 3.582 1.004 3.59 0 6.514-2.88 6.514-6.411S15.07 6.979 11.481 6.979z"/>
        </svg>
        Get Started
      </a>
    </div>
  </section>
</Base>
