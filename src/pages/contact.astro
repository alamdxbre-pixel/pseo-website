---
import Base from '@/layouts/Base.astro';

const siteUrl = import.meta.env.SITE ?? '';
const canonical = `${siteUrl}/contact`;

const phone    = '+971 52 895 506';
const phoneTel = '+97152895506';
const waHref   = `https://wa.me/97152895506?text=${encodeURIComponent("Hi, I'd like to discuss an enterprise technology project.")}`;
const email    = 'aamir@buoyantsolutions.ae';
---

<Base
  title="Contact BuoyantSolutions — Enterprise IT Consultancy UAE"
  description="Start a conversation with BuoyantSolutions. We respond with a written technical assessment within 48 hours. Phone, WhatsApp, or email — no sales calls, no demos."
  canonical={canonical}
  og={{
    title: 'Contact BuoyantSolutions — Enterprise Technology & AI, UAE',
    description: 'Reach our senior engineering team. We respond with a written technical brief within 48 hours.',
    type: 'website',
  }}
>

<!-- ════════════════════════════════════════════════════════
     HERO
════════════════════════════════════════════════════════ -->
<section class="relative bg-[#030B18] text-white overflow-hidden">
  <div class="absolute inset-0 ob-dot-grid pointer-events-none" aria-hidden="true"></div>
  <div class="ob-glow-right" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6 sm:px-10 lg:px-16 py-24 sm:py-32">
    <div class="flex items-center gap-4 mb-12">
      <span class="w-12 h-px bg-blue-400 shrink-0" aria-hidden="true"></span>
      <p class="ob-overline">Start the Conversation</p>
    </div>

    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[0.95] tracking-[-0.04em] mb-8 max-w-3xl">
      Tell Us What<br />
      <span class="text-blue-400">You're Building.</span>
    </h1>

    <p class="text-lg text-slate-400 max-w-xl leading-relaxed">
      We respond with a written technical assessment within 48 hours. No sales calls. No demo decks. Just a direct conversation with the engineers who will do the work.
    </p>
  </div>

  <div class="absolute bottom-0 inset-x-0 ob-rule" aria-hidden="true"></div>
</section>


<!-- ════════════════════════════════════════════════════════
     CONTACT GRID
════════════════════════════════════════════════════════ -->
<section class="bg-white py-24 sm:py-32 px-6 sm:px-10 lg:px-16">
  <div class="max-w-7xl mx-auto grid lg:grid-cols-[1fr_1.4fr] gap-20 items-start">

    <!-- Left: contact methods + what to expect -->
    <div>

      <div class="flex items-center gap-4 mb-10">
        <span class="w-8 h-px bg-blue-500 shrink-0" aria-hidden="true"></span>
        <p class="ob-overline" style="color:#3B82F6">Contact</p>
      </div>

      <h2 class="text-3xl font-extrabold tracking-[-0.03em] text-slate-900 mb-10">
        Reach Us Directly
      </h2>

      <!-- Contact methods -->
      <div class="space-y-0 divide-y divide-slate-100 mb-14">

        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-start gap-5 py-6 group"
        >
          <div class="w-10 h-10 rounded bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0 group-hover:border-blue-200 transition-colors">
            <svg class="w-4 h-4 text-blue-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.533 5.858L0 24l6.336-1.51A11.96 11.96 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.817 9.817 0 01-5.002-1.366l-.358-.213-3.762.896.952-3.665-.234-.377A9.818 9.818 0 012.182 12C2.182 6.573 6.573 2.182 12 2.182S21.818 6.573 21.818 12 17.427 21.818 12 21.818z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">WhatsApp</p>
            <p class="font-semibold text-slate-900 text-base group-hover:text-blue-600 transition-colors">{phone}</p>
            <p class="text-sm text-slate-400 mt-0.5">Fastest response — usually within a few hours</p>
          </div>
        </a>

        <a
          href={`tel:${phoneTel}`}
          class="flex items-start gap-5 py-6 group"
        >
          <div class="w-10 h-10 rounded bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0 group-hover:border-blue-200 transition-colors">
            <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Phone</p>
            <p class="font-semibold text-slate-900 text-base group-hover:text-blue-600 transition-colors">{phone}</p>
            <p class="text-sm text-slate-400 mt-0.5">Sun – Thu, 9:00 AM – 6:00 PM GST</p>
          </div>
        </a>

        <a
          href={`mailto:${email}`}
          class="flex items-start gap-5 py-6 group"
        >
          <div class="w-10 h-10 rounded bg-slate-50 border border-slate-100 flex items-center justify-center shrink-0 group-hover:border-blue-200 transition-colors">
            <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-1">Email</p>
            <p class="font-semibold text-slate-900 text-base group-hover:text-blue-600 transition-colors">{email}</p>
            <p class="text-sm text-slate-400 mt-0.5">Technical assessment returned within 48 hours</p>
          </div>
        </a>

      </div>

      <!-- What to expect -->
      <div class="bg-slate-50 border border-slate-100 rounded-lg p-8">
        <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mb-6">What happens next</p>
        <div class="space-y-5">
          {[
            { step: '01', text: 'We review your project brief and ask any clarifying technical questions.' },
            { step: '02', text: 'Within 48 hours we return a written technical assessment — not a sales pitch.' },
            { step: '03', text: 'If there is a fit, we schedule a direct call with the engineers who will do the work.' },
          ].map((s) => (
            <div class="flex items-start gap-4">
              <span class="font-mono text-xs font-bold text-blue-400 w-5 shrink-0 mt-0.5">{s.step}</span>
              <p class="text-sm text-slate-500 leading-relaxed">{s.text}</p>
            </div>
          ))}
        </div>
      </div>

    </div>

    <!-- Right: project brief form -->
    <div>

      <div class="flex items-center gap-4 mb-10">
        <span class="w-8 h-px bg-blue-500 shrink-0" aria-hidden="true"></span>
        <p class="ob-overline" style="color:#3B82F6">Project Brief</p>
      </div>

      <h2 class="text-3xl font-extrabold tracking-[-0.03em] text-slate-900 mb-10">
        Send a Project Brief
      </h2>

      <form method="POST" action="/api/contact" class="space-y-6" novalidate>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">
              Full Name <span class="text-blue-400">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              autocomplete="name"
              placeholder="Your name"
              class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-900 placeholder-slate-300 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-400/10 transition-colors"
            />
          </div>

          <div>
            <label for="company" class="block text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">
              Company
            </label>
            <input
              type="text"
              id="company"
              name="company"
              autocomplete="organization"
              placeholder="Your organisation"
              class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-900 placeholder-slate-300 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-400/10 transition-colors"
            />
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-5">
          <div>
            <label for="email" class="block text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">
              Email <span class="text-blue-400">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              placeholder="you@company.ae"
              class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-900 placeholder-slate-300 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-400/10 transition-colors"
            />
          </div>

          <div>
            <label for="phone" class="block text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">
              Phone / WhatsApp
            </label>
            <input
              type="tel"
              id="phone"
              name="phone"
              autocomplete="tel"
              placeholder="+971 XX XXX XXXX"
              class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-900 placeholder-slate-300 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-400/10 transition-colors"
            />
          </div>
        </div>

        <div>
          <label for="service" class="block text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">
            Service Area
          </label>
          <select
            id="service"
            name="service"
            class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-900 bg-white focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-400/10 transition-colors"
          >
            <option value="">Select a service…</option>
            <option value="it-consultancy">IT Consultancy</option>
            <option value="custom-software">Custom Software Engineering</option>
            <option value="microservice">Microservice Architecture</option>
            <option value="saas-platform">SaaS Platform Engineering</option>
            <option value="rag-systems">RAG & Knowledge Systems</option>
            <option value="ai-training">AI Model Training & Fine-tuning</option>
            <option value="not-sure">Not Sure — Need Advice</option>
          </select>
        </div>

        <div>
          <label for="message" class="block text-xs font-bold tracking-widest uppercase text-slate-400 mb-2">
            Project Brief <span class="text-blue-400">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="6"
            placeholder="Describe your project — what you are building, your current technology stack, approximate timeline, and any constraints we should know about."
            class="w-full border border-slate-200 rounded px-4 py-3 text-sm text-slate-900 placeholder-slate-300 focus:outline-none focus:border-blue-400 focus:ring-2 focus:ring-blue-400/10 transition-colors resize-none"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full bg-blue-500 hover:bg-blue-600 text-white font-bold py-4 rounded text-sm tracking-wide transition-colors"
        >
          Send Project Brief
        </button>

        <p class="text-xs text-slate-400 text-center leading-relaxed">
          We sign an NDA before any architecture conversation. Your project details are confidential.
        </p>

      </form>
    </div>

  </div>
</section>

</Base>
