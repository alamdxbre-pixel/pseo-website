---
// Base layout — used by all pages.
import '../styles/global.css';
import SeoHead from '@/components/SeoHead.astro';
import Header from '@/components/Header';
import Footer from '@/components/Footer.astro';
import WhatsAppBar from '@/components/WhatsAppBar.astro';
import { ACTIVE_THEME } from '@/lib/flags';

interface RobotsMeta {
  index?: boolean;
  follow?: boolean;
  max_snippet?: number;
  max_image_preview?: 'none' | 'standard' | 'large';
  max_video_preview?: number;
}

interface GeoMeta {
  region: string;
  placename: string;
  position: string;
  icbm: string;
}

interface OgMeta {
  title: string;
  description: string;
  image?: string;
  image_width?: number;
  image_height?: number;
  type?: string;
}

interface Props {
  title?: string;
  description?: string;
  lang?: 'en' | 'ar';
  canonical?: string;
  robots?: RobotsMeta;
  geo?: GeoMeta;
  og?: OgMeta;
  date_modified?: string;
  date_published?: string;
  /** Product context for pre-filled WhatsApp bar link */
  waProduct?: string;
  waVariant?: string;
  waCity?: string;
  /** Full URL of the alternate-language paired page. Passed to SeoHead for hreflang. */
  hreflangPairUrl?: string;
}

const {
  title = 'Marketing Products UAE | Visiting Cards, Apparel & Merchandise',
  description = 'Premium customised marketing products in UAE — visiting cards, T-shirts, caps, office stationery and digital services. Fast delivery across Dubai, Abu Dhabi and GCC.',
  lang = 'en',
  canonical = '/',
  robots,
  geo,
  og,
  date_modified,
  date_published,
  waProduct,
  waVariant,
  waCity,
  hreflangPairUrl,
} = Astro.props;

const isRTL = lang === 'ar';
const siteUrl = import.meta.env.SITE ?? '';
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
const clarityId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID as string | undefined;
---

<!doctype html>
<html lang={lang} dir={isRTL ? 'rtl' : 'ltr'} data-theme={ACTIVE_THEME}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      robots={robots}
      geo={geo}
      og={og}
      lang={lang}
      siteUrl={siteUrl}
      date_modified={date_modified}
      date_published={date_published}
      hreflangPairUrl={hreflangPairUrl}
    />
    <!-- Google Analytics 4 via Partytown (off main thread) -->
    {gaId && (
      <>
        <script
          type="text/partytown"
          src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
        />
        <Fragment
          set:html={`<script type="text/partytown">window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}',{page_path:location.pathname});</script>`}
        />
      </>
    )}
    <!-- Microsoft Clarity via Partytown (off main thread) -->
    {clarityId && (
      <Fragment
        set:html={`<script type="text/partytown">(function(c,l,a,r,i,t,y){c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y)})(window,document,"clarity","script","${clarityId}");</script>`}
      />
    )}
    <!-- Extra head content (JSON-LD, fonts, analytics) -->
    <slot name="head" />
  </head>
  <body class="min-h-screen flex flex-col bg-white text-[var(--color-brand-charcoal)] pb-[72px] md:pb-0">
    <Header client:load currentPath={Astro.url.pathname} />
    <!-- Extra header content (slot for pages that need it) -->
    <slot name="header" />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
    <WhatsAppBar product={waProduct} variant={waVariant} city={waCity} />
  </body>
</html>
